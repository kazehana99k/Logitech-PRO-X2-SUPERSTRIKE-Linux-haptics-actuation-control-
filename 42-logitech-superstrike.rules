# Logitech G PRO X2 SUPERSTRIKE / LIGHTSPEED receiver — allow non-root access to hidraw
# Install:
#   sudo cp 42-logitech-superstrike.rules /etc/udev/rules.d/
#   sudo udevadm control --reload && sudo udevadm trigger
#   (then re-plug the receiver once, or reboot)
#
# LIGHTSPEED receiver (wireless)
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c54d", MODE="0660", TAG+="uaccess"
# Fallback: any Logitech hidraw (covers wired mode, where the product ID may differ)
KERNEL=="hidraw*", ATTRS{idVendor}=="046d", MODE="0660", TAG+="uaccess"
